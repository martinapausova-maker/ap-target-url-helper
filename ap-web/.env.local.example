# Optional: OpenAI API key for semantic matching (embeddings)
# OPENAI_API_KEY=sk-proj-...

# Optional: SeaTable Cloud — sync via "Sync from SeaTable" in the UI
# SEATABLE_BASE_URL=https://cloud.seatable.io
# SEATABLE_API_TOKEN=xxx   # Base API token (40 chars) from SeaTable → Advanced → API Token
# SEATABLE_TABLE_NAME=AP   # Table name (default AP)
# SEATABLE_VIEW_NAME=Volne AP   # Exact view name — only those rows are returned

# Optional: Google Apps Script Web App URL (for shared picks via Sheet)
# APPS_SCRIPT_PICKS_URL=https://script.google.com/macros/s/XXXX/exec
